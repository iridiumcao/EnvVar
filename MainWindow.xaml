<Window x:Class="EnvVar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EnvVar"
        xmlns:model="clr-namespace:EnvVar.Models"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="EnvVar"
        Icon="Resources/app.ico"
        Height="720"
        Width="1200"
        MinHeight="640"
        MinWidth="980">
    <Window.Resources>
        <ObjectDataProvider x:Key="DisplayModes"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="model:DisplayMode" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="VariableLevels"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="model:EnvironmentVariableLevel" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="{DynamicResource Menu_File}">
                <MenuItem Header="{DynamicResource Menu_Export}" Click="ExportMenu_Click" />
                <MenuItem Header="{DynamicResource Menu_Import}" Click="ImportMenu_Click" />
                <Separator />
                <MenuItem Header="{DynamicResource Menu_OpenMetadataDir}" Click="OpenMetadataDir_Click" />
                <Separator />
                <MenuItem Header="{DynamicResource Menu_Exit}" Click="ExitMenu_Click" />
            </MenuItem>
            <MenuItem Header="{DynamicResource Menu_Settings}">
                <MenuItem Header="{DynamicResource Menu_Language}">
                    <MenuItem x:Name="LangZhCN" Header="简体中文" IsCheckable="True" IsChecked="True" Click="LanguageMenu_Click" Tag="zh-CN" />
                    <MenuItem x:Name="LangZhTW" Header="繁體中文" IsCheckable="True" Click="LanguageMenu_Click" Tag="zh-TW" />
                    <MenuItem x:Name="LangEnUS" Header="English" IsCheckable="True" Click="LanguageMenu_Click" Tag="en-US" />
                </MenuItem>
            </MenuItem>
            <MenuItem Header="{DynamicResource Menu_Help}">
                <MenuItem Header="{DynamicResource Menu_About}" Click="AboutMenu_Click" />
            </MenuItem>
        </Menu>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="12"
                Background="#FFF5F5F5"
                BorderBrush="#FFE0E0E0"
                BorderThickness="1"
                CornerRadius="8">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Left">
                    <Button Width="96"
                            Margin="0,0,8,0"
                            Click="RefreshButton_OnClick"
                            Content="{DynamicResource Btn_Refresh}" />
                    <Button Width="96"
                            Margin="0,0,16,0"
                            Click="NewButton_OnClick"
                            Content="{DynamicResource Btn_New}" />
                    <TextBlock VerticalAlignment="Center"
                               Text="{DynamicResource Label_DisplayMode}" />
                    <ComboBox Width="140"
                              Margin="8,0,0,0"
                              ItemsSource="{Binding Source={StaticResource DisplayModes}}"
                              SelectedItem="{Binding DisplayMode, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center"
                               Foreground="#FF666666"
                               Text="{DynamicResource Label_MetadataPrefix}" />
                    <TextBlock VerticalAlignment="Center"
                               Foreground="#FF666666"
                               Text="{Binding MetadataPath}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="0"
                    BorderBrush="#FFE0E0E0"
                    BorderThickness="1"
                    CornerRadius="8">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Padding="12,10"
                            Background="#FFF8F8F8"
                            BorderBrush="#FFE0E0E0"
                            BorderThickness="0,0,0,1">
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="{DynamicResource Label_VariableList}" />
                    </Border>

                    <ListView ItemsSource="{Binding VariablesView}"
                              SelectedItem="{Binding SelectedVariable, Mode=TwoWay}"
                              BorderThickness="0"
                              GridViewColumnHeader.Click="ColumnHeader_Click">
                        <ListView.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,6"
                                                Background="#FFF0F3F6">
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding Name}" />
                                        </Border>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListView.GroupStyle>
                        <ListView.View>
                            <GridView AllowsColumnReorder="False">
                                <GridViewColumn Width="180"
                                                DisplayMemberBinding="{Binding NameDisplay}"
                                                Header="{DynamicResource Col_Name}" />
                                <GridViewColumn Width="140"
                                                DisplayMemberBinding="{Binding Alias}"
                                                Header="{DynamicResource Col_Alias}" />
                                <GridViewColumn Width="90"
                                                DisplayMemberBinding="{Binding Level}"
                                                Header="{DynamicResource Col_Level}" />
                                <GridViewColumn Width="360"
                                                DisplayMemberBinding="{Binding Preview}"
                                                Header="{DynamicResource Col_Preview}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="12"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent" />

            <Border Grid.Column="2"
                    Padding="16"
                    BorderBrush="#FFE0E0E0"
                    BorderThickness="1"
                    CornerRadius="8">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="{Binding Editor.Header}" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="#FF666666"
                                   Text="{DynamicResource Label_EditorHint}" />
                    </StackPanel>

                    <StackPanel Margin="0,16,0,0">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Text="{DynamicResource Label_Name}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding Editor.Name, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Text="{DynamicResource Label_Level}" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Source={StaticResource VariableLevels}}"
                                      SelectedItem="{Binding Editor.Level, Mode=TwoWay}" />
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Text="{DynamicResource Label_Alias}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding Editor.Alias, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Top"
                                       Margin="0,6,0,0"
                                       Text="{DynamicResource Label_Description}" />
                            <TextBox Grid.Column="1"
                                     Height="72"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding Editor.Description, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Top"
                                       Margin="0,6,0,0"
                                       Text="{DynamicResource Label_Value}" />
                            <TextBox Grid.Column="1"
                                     MinHeight="160"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Cascadia Code"
                                     Text="{Binding Editor.Value, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <Border Padding="12"
                                Background="#FFF9FBFD"
                                BorderBrush="#FFDDE6EE"
                                BorderThickness="1"
                                CornerRadius="6"
                                Visibility="{Binding Editor.IsMultiValue, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Text="{DynamicResource Label_SplitPreview}" />
                                <ItemsControl Margin="0,8,0,0"
                                              AlternationCount="2048"
                                              ItemsSource="{Binding Editor.SplitValues}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel Margin="0,2,0,2">
                                                <TextBlock Width="44"
                                                           Foreground="#FF5A6B7A"
                                                           Text="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex), StringFormat=[{0}]}" />
                                                <TextBlock FontFamily="Cascadia Code"
                                                           Text="{Binding}" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <StackPanel Margin="0,16,0,0"
                                    Orientation="Horizontal">
                            <Button Width="96"
                                    Margin="0,0,8,0"
                                    Click="SaveButton_OnClick"
                                    Content="{DynamicResource Btn_Save}" />
                            <Button Width="96"
                                    Margin="0,0,8,0"
                                    Click="DeleteButton_OnClick"
                                    IsEnabled="{Binding CanDeleteCurrent}"
                                    Content="{DynamicResource Btn_Delete}" />
                            <Button Width="96"
                                    Click="CancelButton_OnClick"
                                    Content="{DynamicResource Btn_Cancel}" />
                        </StackPanel>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Margin="0,12,0,0"
                Padding="12,10"
                Background="#FFF8F8F8"
                BorderBrush="#FFE0E0E0"
                BorderThickness="1"
                CornerRadius="8">
            <TextBlock Text="{Binding StatusMessage}" />
        </Border>
    </Grid>
    </DockPanel>
</Window>

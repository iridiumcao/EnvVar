<Window x:Class="EnvVar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EnvVar"
        xmlns:model="clr-namespace:EnvVar.Models"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="EnvVar"
        Icon="Resources/app.ico"
        Height="720"
        Width="1200"
        MinHeight="640"
        MinWidth="980"
        Background="{DynamicResource WindowBackgroundBrush}"
        Closing="MainWindow_OnClosing">
    <Window.Resources>
        <ObjectDataProvider x:Key="DisplayModes"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="model:DisplayMode" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="VariableLevels"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="model:EnvironmentVariableLevel" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="{DynamicResource Menu_File}">
                <MenuItem Header="{DynamicResource Menu_Export}" Click="ExportMenu_Click" />
                <MenuItem Header="{DynamicResource Menu_Import}" Click="ImportMenu_Click" />
                <MenuItem Header="{DynamicResource Menu_OpenDataDir}" Click="OpenDataDir_Click" />
                <MenuItem Header="{DynamicResource Menu_Exit}" Click="ExitMenu_Click" />
            </MenuItem>
            <MenuItem Header="{DynamicResource Menu_Settings}">
                <MenuItem Header="{DynamicResource Menu_Language}">
                    <MenuItem x:Name="LangEnUS" Header="English" IsCheckable="True" IsChecked="True" Click="LanguageMenu_Click" Tag="en-US" />
                    <MenuItem x:Name="LangZhCN" Header="简体中文" IsCheckable="True" Click="LanguageMenu_Click" Tag="zh-CN" />
                    <MenuItem x:Name="LangZhTW" Header="繁體中文" IsCheckable="True" Click="LanguageMenu_Click" Tag="zh-TW" />
                </MenuItem>
                <MenuItem Header="{DynamicResource Menu_Theme}">
                    <MenuItem x:Name="ThemeAuto" Header="{DynamicResource Theme_Auto}" IsCheckable="True" Click="ThemeMenu_Click" Tag="System" />
                    <MenuItem x:Name="ThemeLight" Header="{DynamicResource Theme_Light}" IsCheckable="True" Click="ThemeMenu_Click" Tag="Light" />
                    <MenuItem x:Name="ThemeDark" Header="{DynamicResource Theme_Dark}" IsCheckable="True" Click="ThemeMenu_Click" Tag="Dark" />
                </MenuItem>
                <MenuItem Header="{DynamicResource Menu_MaxHistory}" Click="SettingsMenu_Click" />
                <MenuItem Header="{DynamicResource Menu_Logging}" Click="LoggingSettingsMenu_Click" />
            </MenuItem>
            <MenuItem Header="{DynamicResource Menu_Help}">
                <MenuItem Header="{DynamicResource Menu_StarOnGitHub}" Click="StarOnGitHubMenu_Click" />
                <MenuItem Header="{DynamicResource Menu_ReportIssue}" Click="ReportIssueMenu_Click" />
                <MenuItem Header="{DynamicResource Menu_CheckUpdate}" Click="CheckUpdateMenu_Click" />
                <MenuItem Header="{DynamicResource Menu_About}" Click="AboutMenu_Click" />
            </MenuItem>
        </Menu>

    <Grid Margin="16" Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="12"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Left">
                    <Button Width="96"
                            Margin="0,0,8,0"
                            Click="RefreshButton_OnClick"
                            Content="{DynamicResource Btn_Refresh}" />
                    <Button Width="96"
                            Margin="0,0,16,0"
                            Click="NewButton_OnClick"
                            Content="{DynamicResource Btn_New}" />
                    <TextBlock VerticalAlignment="Center"
                               Text="{DynamicResource Label_DisplayMode}" />
                    <ComboBox Width="140"
                              Margin="8,0,0,0"
                              ItemsSource="{Binding Source={StaticResource DisplayModes}}"
                              SelectedItem="{Binding DisplayMode, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="{DynamicResource Label_MetadataPrefix}" />
                    <TextBlock VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="{Binding MetadataPath}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="0"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Padding="12,10"
                            Background="{DynamicResource PanelBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Text="{DynamicResource Label_VariableList}" />
                            <Grid DockPanel.Dock="Right" Width="160">
                                <TextBox x:Name="SearchBox"
                                         VerticalContentAlignment="Center"
                                         ToolTip="{DynamicResource Label_Search}"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="🔍"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           Margin="6,0,0,0"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DockPanel>
                    </Border>

                    <ListView x:Name="VariableListView"
                              ItemsSource="{Binding VariablesView}"
                              SelectedItem="{Binding SelectedVariable, Mode=TwoWay}"
                              BorderThickness="0"
                              Background="{DynamicResource WindowBackgroundBrush}"
                              GridViewColumnHeader.Click="ColumnHeader_Click"
                              SelectionChanged="VariableListView_OnSelectionChanged"
                              SizeChanged="VariableListView_OnSizeChanged">
                        <ListView.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,6"
                                                Background="{DynamicResource PanelBackgroundBrush}">
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding Name}" />
                                        </Border>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListView.GroupStyle>
                        <ListView.View>
                            <GridView x:Name="VariableGridView" AllowsColumnReorder="False">
                                <GridViewColumn Width="180"
                                                DisplayMemberBinding="{Binding NameDisplay}"
                                                Header="{DynamicResource Col_Name}" />
                                <GridViewColumn Width="140"
                                                DisplayMemberBinding="{Binding Alias}"
                                                Header="{DynamicResource Col_Alias}" />
                                <GridViewColumn Width="90"
                                                DisplayMemberBinding="{Binding Level}"
                                                Header="{DynamicResource Col_Level}" />
                                <GridViewColumn Width="360"
                                                DisplayMemberBinding="{Binding Preview}"
                                                Header="{DynamicResource Col_Preview}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="12"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent" />

            <Border Grid.Column="2"
                    Padding="16"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <DockPanel Grid.IsSharedSizeScope="True">
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="{Binding Editor.Header}" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="{DynamicResource Label_EditorHint}" />
                    </StackPanel>

                    <Grid DockPanel.Dock="Bottom" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="EditorLabel" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal">
                            <Button Width="96"
                                    Margin="0,0,8,0"
                                    Click="SaveButton_OnClick"
                                    Content="{DynamicResource Btn_Save}" />
                            <Button Width="96"
                                    Margin="0,0,8,0"
                                    Click="DeleteButton_OnClick"
                                    IsEnabled="{Binding CanDeleteCurrent}"
                                    Content="{DynamicResource Btn_Delete}" />
                            <Button Width="96"
                                    Margin="0,0,8,0"
                                    Click="CancelButton_OnClick"
                                    Content="{DynamicResource Btn_Cancel}" />
                            <Button x:Name="HistoryButton"
                                    Width="96"
                                    Click="HistoryButton_Click"
                                    IsEnabled="{Binding CanDeleteCurrent}"
                                    Content="{DynamicResource Btn_History}" />
                        </StackPanel>
                    </Grid>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="EditorLabel" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="{DynamicResource Label_Name}" />
                                <TextBox Grid.Column="2"
                                         Text="{Binding Editor.Name, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="EditorLabel" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="{DynamicResource Label_Level}" />
                                <ComboBox Grid.Column="2"
                                          ItemsSource="{Binding Source={StaticResource VariableLevels}}"
                                          SelectedItem="{Binding Editor.Level, Mode=TwoWay}" />
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="EditorLabel" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="{DynamicResource Label_Alias}" />
                                <TextBox Grid.Column="2"
                                         Text="{Binding Editor.Alias, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="EditorLabel" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           VerticalAlignment="Top"
                                           Margin="0,6,0,0"
                                           Text="{DynamicResource Label_Description}" />
                                <TextBox Grid.Column="2"
                                         Height="72"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding Editor.Description, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="EditorLabel" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           VerticalAlignment="Top"
                                           Margin="0,6,0,0"
                                           Text="{DynamicResource Label_Value}" />
                                <TextBox Grid.Column="2"
                                         MinHeight="60"
                                         MaxHeight="240"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontFamily="Cascadia Code"
                                         Text="{Binding Editor.Value, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <Border Padding="12"
                                    Background="{DynamicResource EditorBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Visibility="{Binding Editor.IsMultiValue, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Text="{DynamicResource Label_StructuredEdit}" />
                                        <StackPanel DockPanel.Dock="Right"
                                                    Orientation="Horizontal">
                                            <Button Width="30" Height="30" Margin="2,0"
                                                    Style="{DynamicResource SquareButtonStyle}"
                                                    Content="＋" Click="AddValueItem_Click"
                                                    ToolTip="{DynamicResource Btn_AddItem}" />
                                            <Button Width="30" Height="30" Margin="2,0"
                                                    Style="{DynamicResource SquareButtonStyle}"
                                                    Content="－" Click="RemoveValueItem_Click"
                                                    ToolTip="{DynamicResource Btn_RemoveItem}" />
                                            <Button Width="30" Height="30" Margin="8,0,2,0"
                                                    Style="{DynamicResource SquareButtonStyle}"
                                                    Content="↑" Click="MoveValueItemUp_Click"
                                                    ToolTip="{DynamicResource Btn_MoveUp}" />
                                            <Button Width="30" Height="30" Margin="2,0"
                                                    Style="{DynamicResource SquareButtonStyle}"
                                                    Content="↓" Click="MoveValueItemDown_Click"
                                                    ToolTip="{DynamicResource Btn_MoveDown}" />
                                            <Button Width="30" Height="30" Margin="8,0,2,0"
                                                    Style="{DynamicResource SquareButtonStyle}"
                                                    Content="A↓" Click="SortValuesAsc_Click"
                                                    ToolTip="{DynamicResource Btn_SortAsc}" />
                                            <Button Width="30" Height="30" Margin="2,0"
                                                    Style="{DynamicResource SquareButtonStyle}"
                                                    Content="Z↓" Click="SortValuesDesc_Click"
                                                    ToolTip="{DynamicResource Btn_SortDesc}" />
                                        </StackPanel>
                                    </DockPanel>
                                    <ListBox x:Name="EditableValuesList"
                                             Margin="0,8,0,0"
                                             MaxHeight="300"
                                             ItemsSource="{Binding Editor.EditableValues}"
                                             HorizontalContentAlignment="Stretch">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <DockPanel>
                                                    <TextBlock Width="36"
                                                               Foreground="{DynamicResource HistoryTimestampBrush}"
                                                               VerticalAlignment="Center"
                                                               Text="{Binding Index, StringFormat=[{0}]}" />
                                                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                             FontFamily="Cascadia Code"
                                                             BorderThickness="0"
                                                             Background="Transparent"
                                                             Padding="2,1" />
                                                </DockPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Margin="0,12,0,0"
                Padding="12,10"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <TextBlock Text="{Binding StatusMessage}" />
        </Border>
    </Grid>
    </DockPanel>
</Window>

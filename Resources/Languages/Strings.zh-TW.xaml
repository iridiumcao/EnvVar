<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Menu -->
    <sys:String x:Key="Menu_File">檔案(_F)</sys:String>
    <sys:String x:Key="Menu_Export">匯出(_E)</sys:String>
    <sys:String x:Key="Menu_Import">匯入(_I)</sys:String>
    <sys:String x:Key="Menu_OpenDataDir">開啟資料目錄(_O)</sys:String>
    <sys:String x:Key="Menu_Settings">設定(_S)</sys:String>
    <sys:String x:Key="Menu_MaxHistory">最大歷史記錄(_M)</sys:String>
    <sys:String x:Key="Menu_Logging">日誌(_G)</sys:String>
    <sys:String x:Key="Menu_Exit">結束(_X)</sys:String>
    <sys:String x:Key="Menu_Language">語言(_L)</sys:String>
    <sys:String x:Key="Menu_Theme">主題(_T)</sys:String>
    <sys:String x:Key="Theme_Auto">跟隨系統</sys:String>
    <sys:String x:Key="Theme_Light">淺色</sys:String>
    <sys:String x:Key="Theme_Dark">深色</sys:String>
    <sys:String x:Key="Menu_Help">說明(_H)</sys:String>
    <sys:String x:Key="Menu_CheckUpdate">檢查更新(_U)...</sys:String>
    <sys:String x:Key="Menu_StarOnGitHub">⭐ 在 GitHub 上點讚</sys:String>
    <sys:String x:Key="Menu_ReportIssue">報告問題(_R)</sys:String>
    <sys:String x:Key="Menu_About">關於(_A)</sys:String>

    <!-- Buttons -->
    <sys:String x:Key="Btn_Refresh">重新整理</sys:String>
    <sys:String x:Key="Btn_New">新增</sys:String>
    <sys:String x:Key="Btn_Save">儲存</sys:String>
    <sys:String x:Key="Btn_Delete">刪除</sys:String>
    <sys:String x:Key="Btn_Cancel">取消</sys:String>
    <sys:String x:Key="Btn_OK">確定</sys:String>
    <sys:String x:Key="Btn_Yes">是</sys:String>

    <!-- Messages -->
    <sys:String x:Key="Msg_UpdateAvailable">發現新版本 ({0})，是否前往下載？</sys:String>
    <sys:String x:Key="Msg_UpdateAvailableTitle">發現更新</sys:String>
    <sys:String x:Key="Msg_UpdateNotNeeded">目前已是最新版本。</sys:String>
    <sys:String x:Key="Msg_UpdateNotNeededTitle">已是最新版</sys:String>
    <sys:String x:Key="Msg_UpdateCheckFailed">檢查更新失敗，請稍後重試或檢查網路狀態。</sys:String>
    <sys:String x:Key="Label_MetadataPrefix">中繼資料：</sys:String>
    <sys:String x:Key="Label_VariableList">環境變數清單</sys:String>
    <sys:String x:Key="Label_StructuredEdit">結構化編輯</sys:String>
    <sys:String x:Key="Label_EditorHint">支援使用者級 / 系統級環境變數管理；多值變數會自動顯示分割預覽。</sys:String>
    <sys:String x:Key="Label_Name">名稱</sys:String>
    <sys:String x:Key="Label_Level">級別</sys:String>
    <sys:String x:Key="Label_Alias">別名</sys:String>
    <sys:String x:Key="Label_Description">描述</sys:String>
    <sys:String x:Key="Label_Value">值</sys:String>
    <sys:String x:Key="Label_Preview">預覽</sys:String>

    <!-- Column Headers -->
    <sys:String x:Key="Col_Name">名稱</sys:String>
    <sys:String x:Key="Col_Alias">別名</sys:String>
    <sys:String x:Key="Col_Level">級別</sys:String>
    <sys:String x:Key="Col_Preview">預覽</sys:String>

    <!-- Messages -->
    <sys:String x:Key="Msg_Ready">準備就緒。</sys:String>
    <sys:String x:Key="Msg_LoadFailed">載入環境變數失敗</sys:String>
    <sys:String x:Key="Msg_RefreshFailed">重新整理環境變數失敗</sys:String>
    <sys:String x:Key="Msg_SaveFailed">儲存環境變數失敗</sys:String>
    <sys:String x:Key="Msg_DeleteFailed">刪除環境變數失敗</sys:String>
    <sys:String x:Key="Msg_ConfirmOverwrite">目標名稱和級別下已存在同名環境變數，是否覆蓋？</sys:String>
    <sys:String x:Key="Msg_ConfirmOverwriteTitle">確認覆蓋</sys:String>
    <sys:String x:Key="Msg_ConfirmDelete">確認刪除目前的環境變數？</sys:String>
    <sys:String x:Key="Msg_ConfirmDeleteTitle">確認刪除</sys:String>
    <sys:String x:Key="Msg_NewVariable">請輸入新環境變數資訊。</sys:String>
    <sys:String x:Key="Msg_Selected">已選擇 {0}@{1}。</sys:String>
    <sys:String x:Key="Msg_Loaded">已載入 {0} 個環境變數。</sys:String>
    <sys:String x:Key="Msg_NoVariables">未讀取到環境變數，可直接新增。</sys:String>
    <sys:String x:Key="Msg_Restored">已還原目前選取項目的原始內容。</sys:String>
    <sys:String x:Key="Msg_Saved">已儲存 {0}@{1}。</sys:String>
    <sys:String x:Key="Msg_Deleted">已刪除 {0}@{1}。</sys:String>
    <sys:String x:Key="Msg_CannotDeleteNew">目前是新增狀態，沒有可刪除的環境變數。</sys:String>
    <sys:String x:Key="Msg_NameEmpty">環境變數名稱不可為空。</sys:String>
    <sys:String x:Key="Msg_NameContainsEquals">環境變數名稱不可包含 '='。</sys:String>
    <sys:String x:Key="Msg_InvalidMetadataPath">中繼資料檔案路徑無效。</sys:String>
    <sys:String x:Key="Msg_MetadataReadError">無法讀取中繼資料檔案：{0}。請檢查 JSON 格式。</sys:String>
    <sys:String x:Key="Msg_ExportSuccess">已匯出至 {0}。</sys:String>
    <sys:String x:Key="Msg_ImportSuccess">已匯入 {0} 個環境變數。</sys:String>
    <sys:String x:Key="Msg_ImportConfirm">即將匯入 {0} 個環境變數，已有的同名變數將被覆蓋。是否繼續？</sys:String>
    <sys:String x:Key="Msg_ImportConfirmTitle">確認匯入</sys:String>
    <sys:String x:Key="Msg_AdminRequired">操作系統級環境變數需要系統管理員權限。是否以系統管理員身分重新啟動？</sys:String>
    <sys:String x:Key="Msg_AdminRequiredTitle">權限不足</sys:String>
    <sys:String x:Key="Msg_ExportTitle">匯出環境變數</sys:String>
    <sys:String x:Key="Msg_ImportTitle">匯入環境變數</sys:String>
    <sys:String x:Key="Msg_UnsavedChanges">目前有未儲存的修改。是否在繼續之前儲存修改？</sys:String>
    <sys:String x:Key="Msg_UnsavedChangesTitle">未儲存的修改</sys:String>
    <sys:String x:Key="Msg_JsonFilter">JSON 檔案 (*.json)|*.json</sys:String>
    <sys:String x:Key="Msg_InvalidHistoryCount">請輸入 0 到 10 之間的有效整數。</sys:String>
    <sys:String x:Key="Msg_InvalidLogFileSize">請輸入大於 0 的有效日誌檔案大小整數。</sys:String>
    <sys:String x:Key="Msg_InvalidLoggingSetting">請選擇有效的日誌設定。</sys:String>

    <!-- Settings -->
    <sys:String x:Key="Title_Settings">設定</sys:String>
    <sys:String x:Key="Settings_HistoryLimit">每個變數保留的歷史版本數量 (0-10)：</sys:String>
    <sys:String x:Key="Settings_HistoryLimit_Hint">(設為 0 以停用)</sys:String>
    <sys:String x:Key="Title_LoggingSettings">日誌</sys:String>
    <sys:String x:Key="Settings_LogLevel">日誌級別：</sys:String>
    <sys:String x:Key="Settings_LogRetention">保留時間：</sys:String>
    <sys:String x:Key="Settings_MaxLogFileSize">單檔最大大小：</sys:String>
    <sys:String x:Key="Settings_MaxLogFileSize_Hint">(MB)</sys:String>
    <sys:String x:Key="Settings_LogLevel_Error">錯誤</sys:String>
    <sys:String x:Key="Settings_LogLevel_Warning">警告</sys:String>
    <sys:String x:Key="Settings_LogLevel_Information">資訊</sys:String>
    <sys:String x:Key="Settings_LogLevel_Debug">偵錯</sys:String>
    <sys:String x:Key="Settings_LogRetention_7">7 天</sys:String>
    <sys:String x:Key="Settings_LogRetention_14">14 天</sys:String>
    <sys:String x:Key="Settings_LogRetention_30">30 天</sys:String>
    <sys:String x:Key="Settings_LogRetention_180">180 天</sys:String>
    <sys:String x:Key="Settings_LogRetention_Unlimited">無限制</sys:String>

    <!-- Editor -->
    <sys:String x:Key="Editor_NewHeader">新增環境變數</sys:String>
    <sys:String x:Key="Editor_EditHeader">編輯 {0}@{1}</sys:String>

    <!-- About -->
    <sys:String x:Key="About_Title">關於 EnvVar</sys:String>
    <sys:String x:Key="About_Version">版本</sys:String>
    <sys:String x:Key="About_UpdateDate">更新日期</sys:String>
    <sys:String x:Key="About_Author">作者</sys:String>
    <sys:String x:Key="About_License">授權條款</sys:String>
    <sys:String x:Key="About_ProjectUrl">專案位址</sys:String>
    <sys:String x:Key="About_Description">一個 Windows 環境變數管理工具。</sys:String>
    <sys:String x:Key="About_Close">關閉</sys:String>

    <!-- Search -->
    <sys:String x:Key="Label_Search">搜尋</sys:String>

    <!-- Structured Edit -->
    <sys:String x:Key="Btn_AddItem">新增</sys:String>
    <sys:String x:Key="Btn_RemoveItem">移除</sys:String>
    <sys:String x:Key="Btn_MoveUp">上移</sys:String>
    <sys:String x:Key="Btn_MoveDown">下移</sys:String>
    <sys:String x:Key="Btn_SortAsc">升冪排列</sys:String>
    <sys:String x:Key="Btn_SortDesc">降冪排列</sys:String>

    <!-- History -->
    <sys:String x:Key="Btn_History">歷史</sys:String>
    <sys:String x:Key="Msg_NoHistory">沒有可用的歷史記錄。</sys:String>
    <sys:String x:Key="Msg_HistoryRestored">已從歷史記錄還原值。</sys:String>

</ResourceDictionary>

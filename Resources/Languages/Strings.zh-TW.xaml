<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Menu -->
    <sys:String x:Key="Menu_File">檔案(_F)</sys:String>
    <sys:String x:Key="Menu_Export">匯出(_E)</sys:String>
    <sys:String x:Key="Menu_Import">匯入(_I)</sys:String>
    <sys:String x:Key="Menu_OpenMetadataDir">開啟中繼資料目錄(_O)</sys:String>
    <sys:String x:Key="Menu_Exit">結束(_X)</sys:String>
    <sys:String x:Key="Menu_Settings">設定(_S)</sys:String>
    <sys:String x:Key="Menu_Language">語言(_L)</sys:String>
    <sys:String x:Key="Menu_Help">說明(_H)</sys:String>
    <sys:String x:Key="Menu_About">關於(_A)</sys:String>

    <!-- Buttons -->
    <sys:String x:Key="Btn_Refresh">重新整理</sys:String>
    <sys:String x:Key="Btn_New">新增</sys:String>
    <sys:String x:Key="Btn_Save">儲存</sys:String>
    <sys:String x:Key="Btn_Delete">刪除</sys:String>
    <sys:String x:Key="Btn_Cancel">取消</sys:String>

    <!-- Labels -->
    <sys:String x:Key="Label_DisplayMode">顯示模式：</sys:String>
    <sys:String x:Key="Label_MetadataPrefix">中繼資料：</sys:String>
    <sys:String x:Key="Label_VariableList">環境變數清單</sys:String>
    <sys:String x:Key="Label_SplitPreview">分割預覽（唯讀）</sys:String>
    <sys:String x:Key="Label_EditorHint">支援使用者級 / 系統級環境變數管理；多值變數會自動顯示分割預覽。</sys:String>
    <sys:String x:Key="Label_Name">Name</sys:String>
    <sys:String x:Key="Label_Level">Level</sys:String>
    <sys:String x:Key="Label_Alias">Alias</sys:String>
    <sys:String x:Key="Label_Description">Description</sys:String>
    <sys:String x:Key="Label_Value">Value</sys:String>
    <sys:String x:Key="Label_Preview">Preview</sys:String>

    <!-- Column Headers -->
    <sys:String x:Key="Col_Name">名稱</sys:String>
    <sys:String x:Key="Col_Alias">別名</sys:String>
    <sys:String x:Key="Col_Level">級別</sys:String>
    <sys:String x:Key="Col_Preview">預覽</sys:String>

    <!-- Messages -->
    <sys:String x:Key="Msg_Ready">準備就緒。</sys:String>
    <sys:String x:Key="Msg_LoadFailed">載入環境變數失敗</sys:String>
    <sys:String x:Key="Msg_RefreshFailed">重新整理環境變數失敗</sys:String>
    <sys:String x:Key="Msg_SaveFailed">儲存環境變數失敗</sys:String>
    <sys:String x:Key="Msg_DeleteFailed">刪除環境變數失敗</sys:String>
    <sys:String x:Key="Msg_ConfirmOverwrite">目標名稱和級別下已存在同名環境變數，是否覆蓋？</sys:String>
    <sys:String x:Key="Msg_ConfirmOverwriteTitle">確認覆蓋</sys:String>
    <sys:String x:Key="Msg_ConfirmDelete">確認刪除目前的環境變數？</sys:String>
    <sys:String x:Key="Msg_ConfirmDeleteTitle">確認刪除</sys:String>
    <sys:String x:Key="Msg_NewVariable">請輸入新環境變數資訊。</sys:String>
    <sys:String x:Key="Msg_Selected">已選擇 {0}@{1}。</sys:String>
    <sys:String x:Key="Msg_Loaded">已載入 {0} 個環境變數。</sys:String>
    <sys:String x:Key="Msg_NoVariables">未讀取到環境變數，可直接新增。</sys:String>
    <sys:String x:Key="Msg_Restored">已還原目前選取項目的原始內容。</sys:String>
    <sys:String x:Key="Msg_Saved">已儲存 {0}@{1}。</sys:String>
    <sys:String x:Key="Msg_Deleted">已刪除 {0}@{1}。</sys:String>
    <sys:String x:Key="Msg_CannotDeleteNew">目前是新增狀態，沒有可刪除的環境變數。</sys:String>
    <sys:String x:Key="Msg_NameEmpty">環境變數名稱不可為空。</sys:String>
    <sys:String x:Key="Msg_NameContainsEquals">環境變數名稱不可包含 '='。</sys:String>
    <sys:String x:Key="Msg_InvalidMetadataPath">中繼資料檔案路徑無效。</sys:String>
    <sys:String x:Key="Msg_MetadataReadError">無法讀取中繼資料檔案：{0}。請檢查 JSON 格式。</sys:String>
    <sys:String x:Key="Msg_ExportSuccess">已匯出至 {0}。</sys:String>
    <sys:String x:Key="Msg_ImportSuccess">已匯入 {0} 個環境變數。</sys:String>
    <sys:String x:Key="Msg_ImportConfirm">即將匯入 {0} 個環境變數，已有的同名變數將被覆蓋。是否繼續？</sys:String>
    <sys:String x:Key="Msg_ImportConfirmTitle">確認匯入</sys:String>
    <sys:String x:Key="Msg_AdminRequired">操作系統級環境變數需要系統管理員權限。是否以系統管理員身分重新啟動？</sys:String>
    <sys:String x:Key="Msg_AdminRequiredTitle">權限不足</sys:String>
    <sys:String x:Key="Msg_ExportTitle">匯出環境變數</sys:String>
    <sys:String x:Key="Msg_ImportTitle">匯入環境變數</sys:String>
    <sys:String x:Key="Msg_JsonFilter">JSON 檔案 (*.json)|*.json</sys:String>

    <!-- Editor -->
    <sys:String x:Key="Editor_NewHeader">新增環境變數</sys:String>
    <sys:String x:Key="Editor_EditHeader">編輯 {0}@{1}</sys:String>

    <!-- About -->
    <sys:String x:Key="About_Title">關於 EnvVar</sys:String>
    <sys:String x:Key="About_Version">版本</sys:String>
    <sys:String x:Key="About_Author">作者</sys:String>
    <sys:String x:Key="About_License">授權條款</sys:String>
    <sys:String x:Key="About_ProjectUrl">專案位址</sys:String>
    <sys:String x:Key="About_Description">一個 Windows 環境變數管理工具。</sys:String>
    <sys:String x:Key="About_Close">關閉</sys:String>

</ResourceDictionary>

<Window x:Class="EnvVar.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource About_Title}"
        Width="420"
        Height="340"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    HorizontalAlignment="Center">
            <TextBlock FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Text="EnvVar" />
            <TextBlock Margin="0,4,0,0"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Text="{DynamicResource About_Description}" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0"
                       FontWeight="SemiBold"
                       Text="{DynamicResource About_Version}" />
            <TextBlock Grid.Row="0" Grid.Column="1"
                       x:Name="VersionText" />

            <TextBlock Grid.Row="2" Grid.Column="0"
                       FontWeight="SemiBold"
                       Text="{DynamicResource About_UpdateDate}" />
            <TextBlock Grid.Row="2" Grid.Column="1"
                       x:Name="UpdateDateText" />

            <TextBlock Grid.Row="4" Grid.Column="0"
                       FontWeight="SemiBold"
                       Text="{DynamicResource About_Author}" />
            <TextBlock Grid.Row="4" Grid.Column="1"
                       Text="iridiumcao" />

            <TextBlock Grid.Row="6" Grid.Column="0"
                       FontWeight="SemiBold"
                       Text="{DynamicResource About_License}" />
            <TextBlock Grid.Row="6" Grid.Column="1"
                       Text="Apache License 2.0" />

            <TextBlock Grid.Row="8" Grid.Column="0"
                       FontWeight="SemiBold"
                       Text="{DynamicResource About_ProjectUrl}" />
            <TextBlock Grid.Row="8" Grid.Column="1">
                <Hyperlink x:Name="GitHubLink"
                           NavigateUri="https://github.com/iridiumcao/EnvVar"
                           RequestNavigate="GitHubLink_RequestNavigate">
                    https://github.com/iridiumcao/EnvVar
                </Hyperlink>
            </TextBlock>
        </Grid>

        <Button Grid.Row="4"
                Width="96"
                HorizontalAlignment="Right"
                Content="{DynamicResource About_Close}"
                Click="CloseButton_Click" />
    </Grid>
</Window>

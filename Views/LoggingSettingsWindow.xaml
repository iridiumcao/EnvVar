<Window x:Class="EnvVar.Views.LoggingSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource Title_LoggingSettings}"
        Height="210" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0" Grid.ColumnSpan="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{DynamicResource Settings_LogLevel}" />
            <ComboBox x:Name="LogLevelComboBox" Grid.Row="0" Grid.Column="2" Width="180" HorizontalAlignment="Left" />

            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="{DynamicResource Settings_LogRetention}" />
            <ComboBox x:Name="LogRetentionComboBox" Grid.Row="2" Grid.Column="2" Width="180" HorizontalAlignment="Left" />

            <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="{DynamicResource Settings_MaxLogFileSize}" />
            <StackPanel Grid.Row="4" Grid.Column="2" Orientation="Horizontal">
                <TextBox x:Name="MaxLogFileSizeTextBox" Width="100" VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBlock Text="{DynamicResource Settings_MaxLogFileSize_Hint}" VerticalAlignment="Center" Opacity="0.6" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="{DynamicResource Btn_Save}" Width="80" Margin="0,0,10,0" Click="SaveButton_Click" IsDefault="True" />
            <Button Content="{DynamicResource Btn_Cancel}" Width="80" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
